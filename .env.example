# Server port (default: 3100)
PORT=3100

# Public URL of this server (used in the / info + MCP config template)
SERVER_BASE_URL=https://your-app.railway.app

# ============================================================================
# BROKER-FIRST auth (model "B"). This MCP holds ZERO QuickBooks/Intuit secrets.
# The only secret it carries is a broker *install identity* from the broker's
# POST /register (idempotent). See AUTH.md.
# ============================================================================

# Broker base URL (default: https://connectionsbroker.agenticledger.ai)
BROKER_BASE_URL=https://connectionsbroker.agenticledger.ai

# Install identity from POST /register { "clientNamespace": "<ns>" }
BROKER_CLIENT_NAMESPACE=your-namespace
BROKER_INSTALL_BEARER=your-install-bearer-token
BROKER_JWT_KEY=your-jwt-signing-key

# --- Principal transport (platform-gateway contract) ---
# Header the gateway sets to identify the calling agent (per-agent isolation).
# The value becomes the broker `principal`; broker derives subject = sha256(ns:principal).
BROKER_PRINCIPAL_HEADER=x-broker-principal

# OPTIONAL integrity: if set, the MCP requires X-Broker-Principal-Sig =
# base64url(HMAC-SHA256(principal, key)) so the principal header is unforgeable
# even though this MCP is publicly reachable. Leave unset for pilot/trusted-hop.
# BROKER_PRINCIPAL_HMAC_KEY=shared-gateway-hmac-key

# Principal used when no principal header is present (standalone external Claude).
BROKER_FALLBACK_PRINCIPAL=default

# QBO API base for broker-resolved tokens: production | sandbox (default: production;
# the broker's QuickBooks app is production).
QBO_ENVIRONMENT=production

# --- Raw passthrough escape hatch (holds no secret) ---
# Callers may bypass the broker entirely by sending their own token:
#   Authorization: Bearer <qbo-access-token>
#   X-Realm-Id: <company-realm-id>
#   X-Qbo-Environment: sandbox | production
