# Server port (default: 3100)
PORT=3100

# Public URL of this server (used in OAuth callback display + MCP config instructions)
SERVER_BASE_URL=https://your-app.railway.app

# --- Intuit OAuth App Credentials ---
# Register at https://developer.intuit.com → create an app → get these values
QBO_CLIENT_ID=your-intuit-client-id
QBO_CLIENT_SECRET=your-intuit-client-secret

# Must match EXACTLY what you registered in the Intuit developer portal
QBO_REDIRECT_URI=https://your-app.railway.app/auth/callback

# sandbox or production (default: sandbox)
QBO_ENVIRONMENT=sandbox

# Where to store user tokens (default: ./data/tokens.json)
# TOKEN_STORE_PATH=./data/tokens.json

# --- Legacy passthrough mode ---
# If OAuth vars above are NOT set, users can still connect by passing
# their own raw QBO access tokens via headers:
#   Authorization: Bearer <qbo-access-token>
#   X-Realm-Id: <company-realm-id>
#   X-Qbo-Environment: sandbox | production
